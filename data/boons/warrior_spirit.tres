[gd_resource type="Resource" script_class="BoonData" load_steps=6 format=3]

[ext_resource type="Script" path="res://core/boon_data.gd" id="1_script"]
[ext_resource type="Script" path="res://core/stat_modifier.gd" id="2_mod"]

[sub_resource type="Resource" id="Resource_dmg"]
script = ExtResource("2_mod")
stat = &"damage"
kind = 1
value = 0.05

[sub_resource type="Resource" id="Resource_as"]
script = ExtResource("2_mod")
stat = &"attack_speed"
kind = 1
value = 0.05

[sub_resource type="Resource" id="Resource_ms"]
script = ExtResource("2_mod")
stat = &"move_speed"
kind = 1
value = 0.05

[resource]
script = ExtResource("1_script")
id = &"warrior_spirit"
display_name = "Warrior Spirit"
description = "+5% damage, attack speed and move speed"
weight = 0.6
modifiers = Array[ExtResource("2_mod")]([SubResource("Resource_dmg"), SubResource("Resource_as"), SubResource("Resource_ms")])
